# ─── DATABASE ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/preppilot

# ─── AUTH ───────────────────────────────────────────────────
JWT_SECRET=change-me-to-random-string

# ─── AI PROVIDERS ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# ─── JDOODLE COMPILER ──────────────────────────────────────
JDOODLE_CLIENT_ID=your_client_id
